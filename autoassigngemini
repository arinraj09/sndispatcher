(function() {
    // ==========================================
    // 1. CONFIGURATION VARIABLES (EDIT THESE)
    // ==========================================
    var tableName = 'incident';
    
    // Define all your groups, their queries, and their specific agents here
    var assignmentGroups = [
        {
            id: 'cab_approval', // Unique ID used for saving the browser pointer
            name: 'CAB Approval Group', // Name shown in the dropdown
            query: 'assignment_group=b85d44954a3623120004689b2d5dd60a^assigned_toISEMPTY',
            agents: [
                { name: 'Agent 1 (Bernard)', sys_id: 'ee826bf03710200044e0bfc8bcbe5de6', active: true },
                { name: 'Agent 2 (Christen)', sys_id: '97000fcc0a0a0a6e0104ca999f619e5b', active: true },
                { name: 'Agent 3 (Luke)', sys_id: '46d96f57a9fe198101947a9620895886', active: true }
            ]
        },
        // Add your other groups here...
       {
            id: 'test_group_1', // Unique ID used for saving the browser pointer
            name: 'Test Group 1', // Name shown in the dropdown
            query: 'assignment_group=fa80bd2383058b907c8f9cb6feaad3d2^assigned_toISEMPTY',
            agents: [
                { name: 'Agent 1 (Ron)', sys_id: '62d78687c0a8010e00b3d84178adc913', active: true },
                { name: 'Agent 2 (CAB Approver)', sys_id: 'c97024fe53271300e321ddeeff7b1233', active: true },
                { name: 'Agent 3 (Howard)', sys_id: '46ca0887a9fe19810191e08e51927ebf', active: true }
            ]
        },
    ];

    var currentGroup = assignmentGroups[ 0 ];

    // ==========================================
    // 2. BUILD THE UI DASHBOARD
    // ==========================================
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:999999; display:flex; align-items:center; justify-content:center; font-family:sans-serif;';
    
    var modal = document.createElement('div');
    modal.style.cssText = 'background:#fff; padding:25px; border-radius:8px; width:600px; max-width:90%; box-shadow:0 4px 15px rgba(0,0,0,0.3); display:flex; flex-direction:column;';
    
    var header = document.createElement('h3');
    header.innerText = 'Multi-Group Dispatcher';
    header.style.cssText = 'margin-top:0; margin-bottom:15px; color:#333;';

    var groupSelect = document.createElement('select');
    groupSelect.style.cssText = 'width:100%; padding:8px; margin-bottom:20px; border:1px solid #ccc; border-radius:4px; font-size:14px;';
    
    assignmentGroups.forEach(function(group, index) {
        var option = document.createElement('option');
        option.value = index;
        option.innerText = group.name;
        groupSelect.appendChild(option);
    });

    var agentContainer = document.createElement('div');
    agentContainer.style.cssText = 'display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin-bottom:20px; border-top:1px solid #eee; padding-top:15px;';
    
    function renderAgents() {
        agentContainer.innerHTML = ''; 
        currentGroup.agents.forEach(function(agent) {
            var label = document.createElement('label');
            label.style.cssText = 'display:flex; align-items:center; cursor:pointer; font-size:14px;';
            
            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = agent.active;
            cb.style.marginRight = '8px';
            cb.addEventListener('change', function() { agent.active = cb.checked; });
            
            label.appendChild(cb);
            label.appendChild(document.createTextNode(agent.name));
            agentContainer.appendChild(label);
        });
    }

    groupSelect.addEventListener('change', function() {
        currentGroup = assignmentGroups[this.value];
        renderAgents();
        logMessage('Switched to: ' + currentGroup.name);
    });

    var logArea = document.createElement('div');
    logArea.style.cssText = 'background:#1e1e1e; color:#4af626; font-family:monospace; padding:10px; height:200px; overflow-y:auto; font-size:12px; margin-bottom:15px; white-space:pre-wrap; border-radius:4px; line-height:1.4;';
    
    var btnContainer = document.createElement('div');
    btnContainer.style.cssText = 'display:flex; justify-content:space-between;';

    var runBtn = document.createElement('button');
    runBtn.innerText = 'Fetch & Assign Tickets';
    runBtn.style.cssText = 'padding:10px 20px; background:#278efc; color:#fff; border:none; border-radius:4px; cursor:pointer; font-weight:bold;';
    
    var closeBtn = document.createElement('button');
    closeBtn.innerText = 'Close Dashboard';
    closeBtn.style.cssText = 'padding:10px 20px; background:#dc3545; color:#fff; border:none; border-radius:4px; cursor:pointer; font-weight:bold;';
    closeBtn.addEventListener('click', function() { document.body.removeChild(overlay); });

    btnContainer.appendChild(runBtn);
    btnContainer.appendChild(closeBtn);

    modal.appendChild(header);
    modal.appendChild(groupSelect);
    modal.appendChild(agentContainer);
    modal.appendChild(logArea);
    modal.appendChild(btnContainer);
    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    renderAgents();

    function logMessage(msg) {
        logArea.innerText += msg + '\n';
        logArea.scrollTop = logArea.scrollHeight;
    }

    // ==========================================
    // 3. BULLETPROOF EXECUTION ENGINE
    // ==========================================
    
    // Changed to standard Event Listener to prevent SN Utils stripping the click
    runBtn.addEventListener('click', function() {
        try {
            if (runBtn.disabled) return;
            runBtn.disabled = true;
            runBtn.style.opacity = '0.5';
            logMessage('\n--- Starting assignment for ' + currentGroup.name + ' ---');
            fetchUnassignedTickets();
        } catch (e) {
            logMessage('CRITICAL UI ERROR: ' + e.message);
            runBtn.disabled = false;
            runBtn.style.opacity = '1';
        }
    });

    function fetchUnassignedTickets() {
        try {
            var xhr = new XMLHttpRequest();
            xhr.open('GET', '/api/now/table/' + tableName + '?sysparm_query=' + encodeURIComponent(currentGroup.query) + '&sysparm_fields=sys_id,number', true);
            xhr.setRequestHeader('Accept', 'application/json');
            
            // Look for g_ck in current window, or fallback to top window (if inside an iframe)
            var token = window.g_ck || (window.top && window.top.g_ck);
            if (token) {
                xhr.setRequestHeader('X-UserToken', token);
            } else {
                logMessage('CRITICAL ERROR: window.g_ck is missing. Cannot authenticate API.');
                runBtn.disabled = false;
                runBtn.style.opacity = '1';
                return;
            }

            xhr.onload = function() {
                try {
                    if (xhr.status >= 200 && xhr.status < 300) {
                        var res = JSON.parse(xhr.responseText);
                        var tickets = res.result || [];
                        logMessage('Found ' + tickets.length + ' unassigned tickets.');
                        
                        if (tickets.length > 0) {
                            processAssignments(tickets, 0);
                        } else {
                            runBtn.disabled = false;
                            runBtn.style.opacity = '1';
                        }
                    } else {
                        logMessage('ERROR FETCHING TICKETS: Status ' + xhr.status + ' - ' + xhr.responseText);
                        runBtn.disabled = false;
                        runBtn.style.opacity = '1';
                    }
                } catch(e) {
                    logMessage('ERROR PARSING API RESPONSE: ' + e.message);
                }
            };

            // Added strict error handler for blocked network requests
            xhr.onerror = function() {
                logMessage('NETWORK ERROR: Could not reach ServiceNow REST API.');
                runBtn.disabled = false;
                runBtn.style.opacity = '1';
            };

            xhr.send();
        } catch(e) {
            logMessage('CRITICAL FETCH ERROR: ' + e.message);
            runBtn.disabled = false;
            runBtn.style.opacity = '1';
        }
    }

    function getNextAgent() {
        var storageKey = 'sn_utils_rr_' + currentGroup.id;
        var lastIndex = parseInt(localStorage.getItem(storageKey), 10);
        if (isNaN(lastIndex)) lastIndex = -1;

        var nextIndex = (lastIndex + 1) % currentGroup.agents.length;
        var iterations = 0;

        while (!currentGroup.agents[nextIndex].active && iterations < currentGroup.agents.length) {
            nextIndex = (nextIndex + 1) % currentGroup.agents.length;
            iterations++;
        }

        if (iterations === currentGroup.agents.length) return null;

        localStorage.setItem(storageKey, nextIndex);
        return currentGroup.agents[nextIndex];
    }

    function processAssignments(tickets, index) {
        if (index >= tickets.length) {
            logMessage('--- All assignments complete ---');
            runBtn.disabled = false;
            runBtn.style.opacity = '1';
            return;
        }

        var ticket = tickets[index];
        var targetAgent = getNextAgent();

        if (!targetAgent) {
            logMessage('CRITICAL: No active agents selected! Halting.');
            runBtn.disabled = false;
            runBtn.style.opacity = '1';
            return;
        }

        var xhr = new XMLHttpRequest();
        xhr.open('PUT', '/api/now/table/' + tableName + '/' + ticket.sys_id, true);
        xhr.setRequestHeader('Accept', 'application/json');
        xhr.setRequestHeader('Content-Type', 'application/json');
        
        var token = window.g_ck || (window.top && window.top.g_ck);
        xhr.setRequestHeader('X-UserToken', token);

        var payload = { assigned_to: targetAgent.sys_id };

        xhr.onload = function() {
            if (xhr.status >= 200 && xhr.status < 300) {
                logMessage('SUCCESS: ' + ticket.number + ' -> ' + targetAgent.name);
            } else {
                logMessage('ERROR: Failed to assign ' + ticket.number + ' (Status ' + xhr.status + ')');
                var storageKey = 'sn_utils_rr_' + currentGroup.id;
                var currentIndex = parseInt(localStorage.getItem(storageKey), 10);
                var prevIndex = currentIndex - 1 < 0 ? currentGroup.agents.length - 1 : currentIndex - 1;
                localStorage.setItem(storageKey, prevIndex);
            }
            setTimeout(function() { processAssignments(tickets, index + 1); }, 150);
        };

        xhr.onerror = function() {
            logMessage('NETWORK ERROR assigning ' + ticket.number);
            setTimeout(function() { processAssignments(tickets, index + 1); }, 150);
        };

        xhr.send(JSON.stringify(payload));
    }

})();
