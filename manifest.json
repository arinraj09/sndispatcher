{
  "manifest_version": 2,
  "name": "SN Dispatcher",
  "version": "2.1.0",
  "description": "Round-robin auto-assignment for ServiceNow — floating widget on any SN page.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "browser_action": {
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
    "default_title": "SN Dispatcher — Open Config",
    "default_popup": "popup.html"
  },
  "background": { "scripts": ["background.js"] },
  "content_scripts": [
    {
      "matches": [
        "*://*.service-now.com/*",
        "*://*.mercedes-benz.com/*"
      ],
      "js": ["widget.js"],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "storage",
    "*://*.service-now.com/*",
    "*://*.mercedes-benz.com/*"
  ],
  "web_accessible_resources": ["config.html", "popup.js"],
  "browser_specific_settings": {
    "gecko": {
      "id": "sn-dispatcher@arinraj09",
      "strict_min_version": "140.0",
      "data_collection_permissions": { "required": ["none"], "optional": [] }
    }
  }
}
