(function() {
    var sysId = '';

    // Method 1: The standard g_form API (Best for standard forms)
    if (typeof g_form !== 'undefined' && g_form.getUniqueValue) {
        sysId = g_form.getUniqueValue();
    } 
    
    // Method 2: The global NOW object (Available on older or custom pages)
    if (!sysId && typeof window.NOW !== 'undefined' && window.NOW.sysId) {
        sysId = window.NOW.sysId;
    }

    // Method 3: Fallback to URL parsing using your specific Regex
    if (!sysId) {
        var match = decodeURIComponent(window.location.href).match(/sys_id[=%3D]+([a-f0-9]{32})/i);
        if (match && match[1]) {
            sysId = match[1];
        }
    }

    if (sysId) {
        // Attempt modern clipboard copy
        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(sysId).then(function() {
                showSuccess(sysId);
            }).catch(function() {
                fallbackCopy(sysId);
            });
        } else {
            fallbackCopy(sysId);
        }
    } else {
        alert('Could not detect a sys_id on this page. Make sure a specific record is open.');
    }

    // --- Helper Functions ---

    function showSuccess(id) {
        // If we are on a standard form, use ServiceNow's native blue info banner
        if (typeof g_form !== 'undefined' && g_form.addInfoMessage) {
            g_form.addInfoMessage('✅ Sys_ID copied to clipboard: ' + id);
        } else {
            // Otherwise, inject a temporary floating "Toast" notification
            var toast = document.createElement('div');
            toast.innerText = '✅ Sys_ID Copied: ' + id;
            toast.style.cssText = 'position:fixed; bottom:20px; right:20px; background:#2ea043; color:white; padding:15px; border-radius:5px; z-index:999999; font-family:sans-serif; box-shadow:0 4px 6px rgba(0,0,0,0.2); transition:opacity 0.5s;';
            document.body.appendChild(toast);
            
            // Fade out and remove after 2.5 seconds
            setTimeout(function() { toast.style.opacity = '0'; }, 2000);
            setTimeout(function() { document.body.removeChild(toast); }, 2500);
        }
    }

    function fallbackCopy(id) {
        // Browsers sometimes block clipboard access inside Service Now's iframes.
        // This provides a popup with the ID already highlighted so you can just hit Ctrl+C.
        prompt('Browser security blocked auto-copy. Hit Ctrl+C to copy:', id);
    }

})();
